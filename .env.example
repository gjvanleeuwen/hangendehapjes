# Copy to .env and fill in. Do not commit .env.

# Postmark — transactional email (contact form admin notification + sender confirmation)
# Server API Token from: Servers > [your server] > API Tokens
POSTMARK_TOKEN=replace-with-postmark-server-token

# Telegram — error alerts (unhandled server errors + caught contact-form failures)
# Bot token from @BotFather. Chat ID by messaging the bot once then visiting
# https://api.telegram.org/bot<TOKEN>/getUpdates and reading chat.id from the JSON.
TELEGRAM_BOT_TOKEN=replace-with-bot-token
TELEGRAM_CHAT_ID=replace-with-chat-id

# Public origin — required in production (behind a reverse proxy like Dokploy/Traefik)
# so SvelteKit's CSRF check accepts form POSTs. Leave unset locally.
ORIGIN=https://hangendehapjes.nl

# Admin area (offerte / factuur generator under /admin)
# Single shared password — change to something long and random.
ADMIN_PASSWORD=replace-with-long-random-string

# Postgres — aanvragen/offertes pipeline + funnel metrics (admin only).
# In Dokploy: create a Postgres app, then use its INTERNAL connection string
# (the service hostname on the private Docker network, NOT a public host:port).
# Leave unset locally to run the site without a DB — the pipeline features will
# be inert but the public site and contact form keep working.
DATABASE_URL=postgres://user:password@hh-postgres:5432/hangendehapjes

# Calendar feed — secret token for the subscribable ICS feed at
# /admin/calendar.ics?token=... (calendar apps can't send the admin cookie).
# Use a long random string.
CALENDAR_TOKEN=replace-with-long-random-string
